# Git attributes for line endings and diffs

# Auto detect text files and normalize line endings to LF
* text=auto

# Python
*.py text eol=lf

# Shell scripts
*.sh text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf

# Documentation
*.md text eol=lf
*.txt text eol=lf

# Configuration
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf

# Binary files
*.nmap binary
*.xml binary
*.db binary
